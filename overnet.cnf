dir			= /home/plalonde/git/certainty/ca
oid_section             = overnet_oids

[overnet_oids]
overnetRoles            = 1.3.6.1.4.1.35910.3.1

[ca]
default_ca		= overnet_ca

[overnet_ca]
certificate		= $dir/overnet.pem
database		= $dir/index.txt
new_certs_dir		= $dir/certs
private_key		= $dir/private/overnet_key.pem
serial			= $dir/serial
default_crl_days	= 365
default_days		= 7
default_md		= sha256
policy			= overnet_ca_policy
x509_extensions		= overnet_crt_ext

[overnet_ca_policy]
commonName		= supplied
stateOrProvinceName	= optional
countryName		= optional
emailAddress		= optional
organizationName	= supplied
organizationalUnitName	= optional
 
[overnet_crt_ext]
basicConstraints	= CA:false
extendedKeyUsage	= serverAuth,clientAuth

# This is for the first REQ we do for our root certificate
[req]
default_bits		= 3072
default_keyfile		= $dir/private/overnet_key.pem
default_md		= sha256
prompt			= no
distinguished_name	= root_req_dn
x509_extensions		= root_req_ext

[root_req_dn]
commonName		= Overnet CA
organizationName	= Overnet
emailAddress		= cert@overnet.ca

[root_req_ext]
basicConstraints	= CA:true
overnetRoles            = ASN1:SEQUENCE:ca_roles

[ca_roles]
Role.0                  = UTF8:ca
Role.1                  = UTF8:assume_role
